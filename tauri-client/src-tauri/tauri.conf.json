{
  "productName": "Vibe Board",
  "version": "0.1.0",
  "identifier": "com.vibe-board.app",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://* https://* ws://* wss://*; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "Vibe Board",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24,
      "versionCode": 1
    }
  },
  "plugins": {}
}
